rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider == "google.com";
    }

    function allowedUser() {
      return signedIn()
        && request.auth.token.email != null
        && (
          request.auth.token.email == "jedhfdavidson@gmail.com"
          || request.auth.token.email == "jedhfdavidson@googlemail.com"
          || request.auth.token.email.matches(".*@intuety\\.io$")
        );
    }

    function room(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId));
    }

    function isHost(roomId) {
      return allowedUser() && room(roomId).data.hostUid == request.auth.uid;
    }

    function previousHostMissing(roomId) {
      return room(roomId).data.hostUid == null
        || !exists(/databases/$(database)/documents/rooms/$(roomId)/participants/$(room(roomId).data.hostUid));
    }

    function canClaimHost(roomId) {
      return allowedUser()
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["hostUid", "updatedAt"])
        && previousHostMissing(roomId);
    }

    match /rooms/{roomId} {
      allow read: if allowedUser();

      allow create: if allowedUser()
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.revealed == false
        && request.resource.data.round == 1;

      allow update: if isHost(roomId) || canClaimHost(roomId);
      allow delete: if false;

      match /participants/{userId} {
        allow read: if allowedUser();

        allow create: if allowedUser()
          && request.auth.uid == userId
          && request.resource.data.uid == request.auth.uid;

        allow update: if allowedUser() && (
          (request.auth.uid == userId && request.resource.data.uid == request.auth.uid)
          || isHost(roomId)
        );

        allow delete: if allowedUser() && (request.auth.uid == userId || isHost(roomId));
      }
    }
  }
}
